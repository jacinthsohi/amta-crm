# Copy this file to .env (no .example suffix) and fill in your Supabase
# project's values. You can find them in your Supabase dashboard under
# Project Settings → API.
#
# IMPORTANT: never commit a real .env file to git. The .gitignore already
# excludes it, but this is your reminder.

# The "Project URL" — looks like https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# The "anon public" key — a long string starting with eyJ...
# This key is safe to ship to the browser; it relies on Row-Level Security
# policies (which we set up in Phase 1) to protect your data.
VITE_SUPABASE_ANON_KEY=
